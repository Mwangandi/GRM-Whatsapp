################################################################################
# API Configuration
################################################################################
# Public URL where the service is accessible
API_URL=https://edatuzen.com

# For direct access during development
DEBUG=false

################################################################################
# Dashboard Configuration
################################################################################
DASHBOARD_PORT=8090

################################################################################
# Logging
################################################################################
LOG_LEVEL=info
